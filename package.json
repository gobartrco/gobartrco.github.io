{
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-scss": "^4.0.9",
    "tailwindcss": "^4.1.11"
  },
  "scripts": {
    "build": "npm run postcss:build && bundle exec jekyll build",
    "start": "pm2 start ecosystem.config.cjs && pm2 save",
    "stop": "pm2 stop ecosystem.config.cjs && pm2 delete ecosystem.config.cjs",
    "postcss:build": "postcss _sass/main.scss -o assets/css/main.css --parser postcss-scss"
  },
  "dependencies": {
    "pm2": "^6.0.14",
    "prettier": "^3.8.0"
  }
}
